# AquaVision : GitIgnore (Sécurité Maximale PFE)

# 1. Environnements virtuels (CRITIQUE)
myenv/
venv/
env/
.env

# 2. Fichiers Systèmes & Cache
__pycache__/
*.pyc
.ipynb_checkpoints/
.vscode/
.idea/
*.log
tmp/

# 3. Dossiers Temporaires / Debug
scratch/
__pycache__/

# 4. Fichiers Confidentiels (Présentations, Storyboards, Stratégies)
# -- Markdown (Notes, Plans, Storyboards) --
BIOMASS_REPORT.md
PFE_MEMO_AQUAVISION.md
PIPELINE_ARCHITECTURE.md
SU_T_REPORT.md
astuces.md
